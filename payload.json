{"title":"Conceito Primeira Dobra","slug":"conceito-primeira-dobra","status":"publish","html":"<!DOCTYPE html>\n\n<html class=\"dark\" lang=\"pt-BR\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Manrope:wght@300;400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"on-background\": \"#f9f5f8\",\n              \"on-tertiary\": \"#6a0934\",\n              \"error-dim\": \"#d73357\",\n              \"surface-container-low\": \"#131315\",\n              \"surface-container-highest\": \"#262528\",\n              \"inverse-surface\": \"#fcf8fb\",\n              \"surface-bright\": \"#2c2c2f\",\n              \"tertiary-dim\": \"#f0779d\",\n              \"surface-dim\": \"#0e0e10\",\n              \"on-primary-fixed\": \"#000000\",\n              \"tertiary-fixed-dim\": \"#f67ca3\",\n              \"surface-container\": \"#19191c\",\n              \"on-tertiary-fixed\": \"#380018\",\n              \"on-secondary-fixed-variant\": \"#005e64\",\n              \"on-surface-variant\": \"#adaaad\",\n              \"tertiary-container\": \"#fd81a8\",\n              \"primary-dim\": \"#9c48ea\",\n              \"primary-fixed-dim\": \"#b971ff\",\n              \"on-secondary\": \"#005359\",\n              \"primary-fixed\": \"#c284ff\",\n              \"secondary-fixed-dim\": \"#00deec\",\n              \"on-error\": \"#490013\",\n              \"on-primary-container\": \"#360061\",\n              \"on-primary-fixed-variant\": \"#430076\",\n              \"on-tertiary-fixed-variant\": \"#701039\",\n              \"surface-tint\": \"#cc97ff\",\n              \"tertiary-fixed\": \"#ff8eb0\",\n              \"on-secondary-container\": \"#e3fdff\",\n              \"surface-variant\": \"#262528\",\n              \"error\": \"#ff6e84\",\n              \"error-container\": \"#a70138\",\n              \"primary-container\": \"#c284ff\",\n              \"secondary-fixed\": \"#00eefc\",\n              \"inverse-primary\": \"#842cd3\",\n              \"surface-container-high\": \"#1f1f22\",\n              \"secondary-dim\": \"#00deec\",\n              \"on-error-container\": \"#ffb2b9\",\n              \"tertiary\": \"#ff97b5\",\n              \"background\": \"#0e0e10\",\n              \"secondary\": \"#00eefc\",\n              \"on-surface\": \"#f9f5f8\",\n              \"primary\": \"#cc97ff\",\n              \"inverse-on-surface\": \"#565457\",\n              \"on-primary\": \"#47007c\",\n              \"outline\": \"#767577\",\n              \"secondary-container\": \"#006970\",\n              \"on-tertiary-container\": \"#59002a\",\n              \"surface-container-lowest\": \"#000000\",\n              \"surface\": \"#0e0e10\",\n              \"on-secondary-fixed\": \"#003f43\",\n              \"outline-variant\": \"#48474a\"\n            },\n            fontFamily: {\n              \"headline\": [\"Space Grotesk\"],\n              \"body\": [\"Manrope\"],\n              \"label\": [\"Manrope\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\"},\n          },\n        },\n      }\n    </script>\n<style>\n      .material-symbols-outlined {\n        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n      }\n      .glass-card {\n        background: rgba(38, 37, 40, 0.4);\n        backdrop-filter: blur(20px);\n        -webkit-backdrop-filter: blur(20px);\n      }\n      .hero-gradient {\n        background: radial-gradient(circle at 50% 50%, rgba(204, 151, 255, 0.08) 0%, rgba(14, 14, 16, 0) 70%);\n      }\n    </style>\n</head>\n<body class=\"bg-background text-on-surface font-body selection:bg-primary/30\">\n<!-- Top Navigation -->\n<nav class=\"fixed top-0 w-full z-50 bg-[#0e0e10]/40 backdrop-blur-xl shadow-[0_20px_50px_rgba(139,92,246,0.06)]\">\n<div class=\"flex justify-between items-center px-8 py-6 max-w-7xl mx-auto\">\n<div class=\"text-2xl font-black tracking-tighter text-[#f9f5f8] font-headline\">\n                LUMINAL\n            </div>\n<div class=\"hidden md:flex items-center gap-12\">\n<a class=\"text-[#cc97ff] border-b-2 border-[#cc97ff] pb-1 font-headline font-bold tracking-tight\" href=\"#\">Home</a>\n<a class=\"text-[#f9f5f8]/70 hover:text-[#f9f5f8] transition-colors font-headline font-bold tracking-tight\" href=\"#\">Portfolio</a>\n<a class=\"text-[#f9f5f8]/70 hover:text-[#f9f5f8] transition-colors font-headline font-bold tracking-tight\" href=\"#\">Services</a>\n</div>\n<button class=\"bg-gradient-to-r from-primary to-primary-dim text-on-primary-fixed font-label font-bold px-6 py-3 rounded-full hover:scale-105 transition-transform duration-300\">\n                Start Your Project\n            </button>\n</div>\n</nav>\n<main class=\"relative min-h-screen flex flex-col items-center pt-32 overflow-hidden\">\n<!-- Ambient background elements -->\n<div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-full h-full hero-gradient pointer-events-none\"></div>\n<div class=\"absolute -top-24 -left-24 w-96 h-96 bg-primary/5 rounded-full blur-[120px] pointer-events-none\"></div>\n<div class=\"absolute top-1/2 -right-24 w-96 h-96 bg-secondary/5 rounded-full blur-[120px] pointer-events-none\"></div>\n<!-- Hero Content Wrapper -->\n<section class=\"relative z-10 w-full max-w-7xl px-8 flex flex-col items-center text-center\">\n<!-- Badge -->\n<div class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-sm glass-card border border-outline-variant/15 mb-8\">\n<span class=\"w-2 h-2 rounded-full bg-secondary shadow-[0_0_10px_#00eefc]\"></span>\n<span class=\"text-xs font-label uppercase tracking-widest text-secondary/80 font-bold\">A Nova Era da Produção Digital</span>\n</div>\n<!-- Main Headline -->\n<h1 class=\"font-headline font-bold text-5xl md:text-7xl lg:text-8xl tracking-tighter leading-[0.9] max-w-5xl mb-8\">\n                Do Pensamento ao Conteúdo de <span class=\"text-transparent bg-clip-text bg-gradient-to-br from-primary via-primary-fixed to-secondary\">Alta Conversão</span>\n</h1>\n<!-- Subheadline -->\n<p class=\"font-body text-lg md:text-xl text-on-surface-variant max-w-2xl leading-relaxed mb-12\">\n                Transformamos suas ideias com a velocidade da IA e a precisão do olhar humano. Criatividade escalável, resultados reais.\n            </p>\n<!-- CTA -->\n<div class=\"flex flex-col sm:flex-row gap-4 mb-24\">\n<button class=\"bg-gradient-to-r from-primary to-primary-dim text-on-primary-fixed font-label font-bold px-10 py-5 rounded-full hover:scale-105 transition-all shadow-[0_10px_40px_rgba(204,151,255,0.2)]\">\n                    Transformar Minha Ideia Agora\n                </button>\n<button class=\"px-10 py-5 rounded-full font-label font-bold border border-outline-variant/30 hover:bg-surface-container-highest transition-colors flex items-center gap-2\">\n                    Ver Portfólio\n                    <span class=\"material-symbols-outlined text-sm\">arrow_forward</span>\n</button>\n</div>\n<!-- Visual Metaphor Section -->\n<div class=\"relative w-full max-w-6xl mx-auto py-20 flex flex-col md:flex-row items-center justify-between gap-12 lg:gap-0\">\n<!-- Left: Abstract Ideas -->\n<div class=\"flex-1 flex flex-col items-center md:items-end gap-6 relative\">\n<div class=\"absolute right-0 top-1/2 -translate-y-1/2 w-48 h-px bg-gradient-to-r from-transparent to-primary/40 hidden lg:block\"></div>\n<div class=\"glass-card p-4 rounded-xl border border-outline-variant/10 self-center md:self-end rotate-[-3deg] hover:rotate-0 transition-transform\">\n<p class=\"text-sm font-label text-primary-dim italic\">\"Um manifesto sobre futuro...\"</p>\n</div>\n<div class=\"glass-card p-4 rounded-xl border border-outline-variant/10 self-center md:mr-12 rotate-[2deg] hover:rotate-0 transition-transform\">\n<div class=\"flex gap-2\">\n<span class=\"material-symbols-outlined text-primary text-sm\" style=\"font-variation-settings: 'FILL' 1;\">blur_on</span>\n<p class=\"text-xs font-headline font-medium tracking-tight\">INSIGHT_NODE_042</p>\n</div>\n</div>\n<div class=\"glass-card p-4 rounded-xl border border-outline-variant/10 self-center md:self-end rotate-[-1deg] hover:rotate-0 transition-transform\">\n<p class=\"text-sm font-label text-on-surface-variant\">Conceito: Minimalismo High-Tech</p>\n</div>\n</div>\n<!-- Center: The Bulb -->\n<div class=\"relative w-64 h-64 md:w-80 md:h-80 flex items-center justify-center z-20\">\n<!-- Glowing aura -->\n<div class=\"absolute inset-0 bg-primary/20 rounded-full blur-[60px]\"></div>\n<div class=\"absolute inset-4 bg-secondary/10 rounded-full blur-[40px]\"></div>\n<!-- Bulb Image -->\n<div class=\"relative w-full h-full rounded-full border border-primary/20 p-8 glass-card\">\n<img alt=\"Light bulb glowing\" class=\"w-full h-full object-contain filter drop-shadow-[0_0_30px_rgba(204,151,255,0.6)]\" data-alt=\"A futuristic glass light bulb floating in a dark space, glowing intensely with vibrant violet and cyan filaments, reflecting on dark obsidian surfaces\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCbqXWHMbF95fd5Jmz3-Q00j9HZAHk8Hf8AwRp-VCQLP0t6gaRo8j5KuSsQEow5AqOgQUNFXl41lqh-LzkXW1f_PdO19IgkyJ1zffXINJz2Zol_s8GDD68epcord0RfeaflJHYqR6p2Pmgr1jN5WV-22IbJ6G8p0xj-2NiwRbh10Wrh1A_FjVhvUDNLxcjC1PGZJzCuJcIDn3H29l8Nwt6hpJq-Llc4MT_5muHjILwWPRJ0U7qvpQtYo6JL7lWXc2DJqxpCp_e9624\"/>\n</div>\n<!-- Flow indicators -->\n<div class=\"absolute -left-12 top-1/2 hidden lg:block\">\n<span class=\"material-symbols-outlined text-primary animate-pulse\">double_arrow</span>\n</div>\n<div class=\"absolute -right-12 top-1/2 hidden lg:block\">\n<span class=\"material-symbols-outlined text-secondary animate-pulse\">double_arrow</span>\n</div>\n</div>\n<!-- Right: High-Converting Content -->\n<div class=\"flex-1 flex flex-col items-center md:items-start gap-6 relative\">\n<div class=\"absolute left-0 top-1/2 -translate-y-1/2 w-48 h-px bg-gradient-to-r from-secondary/40 to-transparent hidden lg:block\"></div>\n<!-- Content Card 1: Ad -->\n<div class=\"glass-card p-1 rounded-xl border border-secondary/20 w-48 rotate-[3deg] hover:rotate-0 transition-all hover:scale-105\">\n<div class=\"h-24 w-full bg-surface-container-highest rounded-lg mb-2 overflow-hidden\">\n<div class=\"w-full h-full bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-secondary opacity-40\">play_circle</span>\n</div>\n</div>\n<div class=\"px-2 pb-2\">\n<div class=\"h-2 w-20 bg-secondary/30 rounded-full mb-2\"></div>\n<div class=\"h-1.5 w-full bg-outline-variant/20 rounded-full mb-1\"></div>\n<div class=\"h-1.5 w-2/3 bg-outline-variant/20 rounded-full\"></div>\n</div>\n</div>\n<!-- Content Card 2: Analytics -->\n<div class=\"glass-card p-4 rounded-xl border border-secondary/20 md:ml-12 flex items-center gap-4 rotate-[-2deg] hover:rotate-0 transition-all\">\n<div class=\"p-2 bg-secondary/10 rounded-lg\">\n<span class=\"material-symbols-outlined text-secondary text-xl\">trending_up</span>\n</div>\n<div>\n<p class=\"text-[10px] uppercase tracking-tighter text-secondary/60 font-bold\">Conversion Rate</p>\n<p class=\"text-xl font-headline font-bold text-on-surface\">+342%</p>\n</div>\n</div>\n<!-- Content Card 3: Social -->\n<div class=\"glass-card p-3 rounded-xl border border-outline-variant/10 flex gap-3 rotate-[1deg] hover:rotate-0 transition-all\">\n<div class=\"w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-xs\">share</span>\n</div>\n<div class=\"space-y-1\">\n<div class=\"h-1.5 w-24 bg-outline-variant/20 rounded-full\"></div>\n<div class=\"h-1.5 w-16 bg-outline-variant/10 rounded-full\"></div>\n</div>\n</div>\n</div>\n</div>\n</section>\n<!-- Trusted by / Stats -->\n<section class=\"w-full max-w-7xl px-8 py-20 border-t border-outline-variant/5\">\n<div class=\"grid grid-cols-2 md:grid-cols-4 gap-8\">\n<div class=\"flex flex-col items-center\">\n<span class=\"text-4xl font-headline font-bold text-primary mb-2\">12M+</span>\n<span class=\"text-xs font-label uppercase tracking-widest text-on-surface-variant\">Impressões Geradas</span>\n</div>\n<div class=\"flex flex-col items-center\">\n<span class=\"text-4xl font-headline font-bold text-secondary mb-2\">85%</span>\n<span class=\"text-xs font-label uppercase tracking-widest text-on-surface-variant\">Mais Rápido que Agências</span>\n</div>\n<div class=\"flex flex-col items-center\">\n<span class=\"text-4xl font-headline font-bold text-on-surface mb-2\">500+</span>\n<span class=\"text-xs font-label uppercase tracking-widest text-on-surface-variant\">Projetos Ativos</span>\n</div>\n<div class=\"flex flex-col items-center\">\n<span class=\"text-4xl font-headline font-bold text-primary-fixed mb-2\">24/7</span>\n<span class=\"text-xs font-label uppercase tracking-widest text-on-surface-variant\">Escalabilidade IA</span>\n</div>\n</div>\n</section>\n</main>\n<footer class=\"bg-[#131315] w-full rounded-t-[2rem]\">\n<div class=\"flex flex-col md:flex-row justify-between items-center px-12 py-16 gap-8 w-full max-w-7xl mx-auto\">\n<div class=\"text-xl font-bold text-[#f9f5f8] font-headline\">LUMINAL</div>\n<div class=\"flex gap-8\">\n<a class=\"text-[#f9f5f8]/50 hover:text-[#00eefc] transition-colors duration-200 text-sm font-body tracking-wide\" href=\"#\">Contact</a>\n<a class=\"text-[#f9f5f8]/50 hover:text-[#00eefc] transition-colors duration-200 text-sm font-body tracking-wide\" href=\"#\">Instagram</a>\n<a class=\"text-[#f9f5f8]/50 hover:text-[#00eefc] transition-colors duration-200 text-sm font-body tracking-wide\" href=\"#\">LinkedIn</a>\n</div>\n<div class=\"text-[#f9f5f8]/50 text-sm font-body tracking-wide\">\n                © 2024 Luminal Studio. Synthetic Elegance.\n            </div>\n</div>\n</footer>\n</body></html>"}